    "Even/Odd & Multiple Checker"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "77a938b3-3d79-48cc-8d7e-319ff352dbd6",
   "metadata": {},
   "outputs": [
    {
     "name": "stdin",
     "output_type": "stream",
     "text": [
      "Enter starting number:  40\n",
      "Enter ending number:  60\n"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "40 → Even & Multiple of 5!!\n",
      "41\n",
      "43\n",
      "44 → Even\n",
      "45 → Multiple of 5!\n",
      "46 → Even\n",
      "47\n",
      "48 → Even\n",
      "50 → Even & Multiple of 5!!\n",
      "51\n",
      "52 → Even\n",
      "53\n",
      "54 → Even\n",
      "55 → Multiple of 5!\n",
      "57\n",
      "58 → Even\n",
      "59\n",
      "60 → Even & Multiple of 5!!\n"
     ]
    }
   ],
   "source": [
    "# Asking user for starting and ending numbers\n",
    "start = int(input(\"Enter starting number: \"))\n",
    "end = int(input(\"Enter ending number: \"))\n",
    "\n",
    "# Using while loop\n",
    "num = start\n",
    "\n",
    "while num <= end:\n",
    "\n",
    "    # Skip numbers divisible by 7\n",
    "    if num % 7 == 0:\n",
    "        num += 1\n",
    "        continue\n",
    "\n",
    "    # Check conditions\n",
    "    if num % 2 == 0 and num % 5 == 0:\n",
    "        print(f\"{num} → Even & Multiple of 5!!\")\n",
    "\n",
    "    elif num % 2 == 0:\n",
    "        print(f\"{num} → Even\")\n",
    "\n",
    "    elif num % 5 == 0:\n",
    "        print(f\"{num} → Multiple of 5!\")\n",
    "\n",
    "    else:\n",
    "        print(num)\n",
    "\n",
    "    num += 1"
   ]
